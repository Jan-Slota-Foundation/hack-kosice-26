// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  name      String
  role      UserRole @default(PATIENT)

  doctorId String? @db.Uuid
  doctor   User?   @relation("DoctorPatients", fields: [doctorId], references: [id], onDelete: SetNull)
  patients User[]  @relation("DoctorPatients")

  jobs   AnalysisJob[]
  images RawImage[]

  @@index([doctorId])
}

enum UserRole {
  DOCTOR
  PATIENT
}

enum JobStatus {
  PROCESSING
  FINISHED
  ERROR
}

model AnalysisJob {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  status     JobStatus @default(PROCESSING)
  error      String?
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  creatorId String @db.Uuid
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  images RawImage[]

  @@index([creatorId, createdAt(sort: Desc)])
}

model RawImage {
  id          String   @id @default(uuid()) @db.Uuid
  filename    String
  contentType String
  storagePath String   @unique
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String      @db.Uuid
  job   AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
}
